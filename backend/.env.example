# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/manufacturing_db?schema=public"

# Redis Configuration (BullMQ & Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MQTT Broker Configuration (VerneMQ)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=admin
MQTT_PASSWORD=admin
MQTT_CLIENT_ID=admin-backend

# JWT Configuration
JWT_SECRET=super_secret_key_change_in_production
JWT_REFRESH_SECRET=super_refresh_secret_change_in_production
JWT_EXPIRES_IN=1d

# Logging Configuration
LOG_LEVEL=info
